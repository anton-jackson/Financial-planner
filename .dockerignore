# Runtime data (not part of the image)
backend/data/profile.yaml
backend/data/assets.yaml
backend/data/results
backend/data/agent_sandbox
data/

# Deploy configs (contain secrets)
deploy/*.env
!deploy/config.example.env

# Docs (not needed in container)
docs/
