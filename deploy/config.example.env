# ─── GCP Project ─────────────────────────────────────────────────────
# Your GCP project ID. Find it: gcloud projects list
GCP_PROJECT=

# Region for Cloud Run and Artifact Registry
GCP_REGION=us-central1

# ─── Instance ────────────────────────────────────────────────────────
# Short name for this instance (lowercase, no spaces). Used in:
#   - Cloud Run service name: finplanner-${INSTANCE_NAME}
#   - GCS bucket name: ${GCP_PROJECT}-finplanner-${INSTANCE_NAME}
INSTANCE_NAME=

# ─── Auth ────────────────────────────────────────────────────────────
# Google OAuth client ID (from console.cloud.google.com > APIs > Credentials)
GOOGLE_CLIENT_ID=

# The single email address allowed to access this instance
ALLOWED_EMAIL=

# ─── Domain (optional) ──────────────────────────────────────────────
# Custom domain for this instance (e.g., alice.finance.example.com)
# Leave empty to use the auto-generated Cloud Run URL.
CUSTOM_DOMAIN=

# ─── AWS Route 53 (optional) ────────────────────────────────────────
# If set, the deploy script auto-creates a CNAME record for CUSTOM_DOMAIN.
# Find your zone ID: ./deploy/deploy.sh --list-zones
# Leave empty to skip DNS automation (you'll create the record manually).
AWS_HOSTED_ZONE_ID=

# ─── AI Advisor (optional) ──────────────────────────────────────────
# Anthropic API key. Leave empty to disable the AI advisor.
ANTHROPIC_API_KEY=

# ─── Image ───────────────────────────────────────────────────────────
# Container image tag. Default builds and pushes to Artifact Registry.
# Override to use a pre-built image.
IMAGE_TAG=latest
